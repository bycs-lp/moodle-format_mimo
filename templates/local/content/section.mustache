{{!
    @template format_minimoodlewall/local/content/section

    Displays a course section as a minimal wall showing all activities.

    This template extends the core section template.
}}
{{< core_courseformat/local/content/section }}
    {{! Override the cmlist block to display activities in a custom wall format. }}
    {{$ core_courseformat/local/content/section/cmlist }}
        {{! Live region for filter status announcements }}
        <div class="sr-only" role="status" aria-live="polite" aria-atomic="true" data-region="filter-status"></div>
        {{! Live region for pagination status announcements }}
        <div class="sr-only" role="status" aria-live="polite" aria-atomic="true" data-region="pagination-status"></div>
        {{! Background design wrapper — applies theme class to filter bar, board and navigation. }}
        <div class="mmw-bgdesign-wrapper{{#bgdesignclass}} {{bgdesignclass}}{{/bgdesignclass}}">
        {{#filterbar.hasitems}}
        <div class="minimoodlewall-filterbar {{styleclass}}" data-region="minimoodlewall-filterbar" data-testid="filter-bar" role="toolbar" aria-label="{{filterbar.label}}" data-style="{{stylevariant}}">
            {{#filterbar.tags}}
            <button
                type="button"
                class="minimoodlewall-filterbar-button is-empty"
                data-action="tag-filter"
                data-testid="filter-button"
                data-tagid="{{id}}"
                data-tag-name="{{name}}"
                data-hasactivities="{{#hasactivities}}1{{/hasactivities}}{{^hasactivities}}0{{/hasactivities}}"
                aria-pressed="false"
                title="{{name}}{{^hasactivities}}{{#filterbar.isediting}} · {{filterbar.emptylabel}}{{/filterbar.isediting}}{{/hasactivities}}"
                style="{{#bgcolor}}--mmw-filter-accent: {{bgcolor}};{{/bgcolor}}"
                disabled
            >
                <span class="sr-only">{{#str}}filterby, format_minimoodlewall{{/str}} {{name}}</span>
                <span class="minimoodlewall-filterbar-symbol">
                    {{#imageurl}}
                    <img src="{{imageurl}}" alt="{{name}}">
                    {{/imageurl}}
                    {{^imageurl}}
                    <span class="minimoodlewall-filterbar-label">{{name}}</span>
                    {{/imageurl}}
                </span>
            </button>
            {{/filterbar.tags}}
        </div>
        {{/filterbar.hasitems}}
        {{#cmlist}}
        <ul class="section m-0 minimoodlewall-activities row g-3 {{styleclass}}{{#bgdesignclass}} {{bgdesignclass}}{{/bgdesignclass}}{{#hasinitialnext}} pagination-active{{/hasinitialnext}}" data-for="cmlist" data-style="{{stylevariant}}" style="list-style: none;">
            {{#cms}}
            {{#cmitem}}
                {{$ core_courseformat/local/content/section/cmitem}}
                    {{> format_minimoodlewall/local/content/section/cmitem}}
                {{/ core_courseformat/local/content/section/cmitem}}
            {{/cmitem}}
            {{/cms}}
        </ul>
        <div class="minimoodlewall-navigation-wrapper {{styleclass}}" data-style="{{stylevariant}}" role="navigation" aria-label="{{#str}}paginationnavigation, format_minimoodlewall{{/str}}">
            {{! Pagination navigation }}
            <div
                class="minimoodlewall-navigation justify-content-end align-items-center gap-3 is-booting"
                data-activity-count="{{activitycount}}"
                data-placeholder-threshold="{{initialpaginationthreshold}}"
                data-has-next="{{#hasinitialnext}}1{{/hasinitialnext}}{{^hasinitialnext}}0{{/hasinitialnext}}"
            >
                <button
                    type="button"
                    id="minimoodlewall-prev"
                    class="minimoodlewall-nav-btn minimoodlewall-nav-btn--prev"
                    aria-label="{{#str}}previouspage, format_minimoodlewall{{/str}}"
                    aria-disabled="true"
                    disabled
                >
                    <svg class="minimoodlewall-nav-arrow" viewBox="0 0 32 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M13 2L2 12L13 22V17H28V7H13V2Z" stroke="currentColor" stroke-width="0.5" stroke-linejoin="round"/>
                    </svg>
                </button>
                <button
                    type="button"
                    id="minimoodlewall-next"
                    class="minimoodlewall-nav-btn minimoodlewall-nav-btn--next"
                    aria-label="{{#str}}nextpage, format_minimoodlewall{{/str}}"
                    aria-disabled="true"
                    disabled
                >
                    <svg class="minimoodlewall-nav-arrow" viewBox="0 0 32 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M19 2L30 12L19 22V17H4V7H19V2Z" stroke="currentColor" stroke-width="0.5" stroke-linejoin="round"/>
                    </svg>
                </button>
            </div>
        </div>
        {{#completionstatus}}
        {{! Completion status indicator region }}
        <div class="minimoodlewall-completion-status {{styleclass}}" data-region="completion-status" data-style="{{stylevariant}}">
            {{! Active tag image overlay - shown when tag filter is active }}
            <div class="completion-status-tag-image" data-region="active-tag-image" hidden>
                <img src="" alt="" class="completion-status-tag-img">
            </div>
            {{! Completion filter pills }}
            <div class="completion-status-pills" role="group" aria-label="{{#str}}completionfilter, format_minimoodlewall{{/str}}">
                <button
                    type="button"
                    class="completion-pill completion-pill--complete"
                    data-action="completion-filter"
                    data-completed="true"
                    aria-pressed="false"
                    aria-label="{{#str}}showcompletedactivities, format_minimoodlewall{{/str}}"
                >
                    <span class="completion-pill-icon" aria-hidden="true">
                        <i class="fa fa-check"></i>
                    </span>
                    <span class="completion-pill-count" data-count="completed">{{completedcount}}</span>
                </button>
                <button
                    type="button"
                    class="completion-pill completion-pill--incomplete"
                    data-action="completion-filter"
                    data-completed="false"
                    aria-pressed="false"
                    aria-label="{{#str}}showincompleteactivities, format_minimoodlewall{{/str}}"
                >
                    <span class="completion-pill-icon" aria-hidden="true">
                        <i class="fa fa-times"></i>
                    </span>
                    <span class="completion-pill-count" data-count="incomplete">{{incompletecount}}</span>
                </button>
                {{#enablecompletionstars}}
                {{! Completion stars - one gold star per completed activity }}
                <div class="completion-stars{{#allcomplete}} all-complete{{/allcomplete}}"
                     data-region="completion-stars"
                     data-completed-count="{{completedcount}}"
                     role="img"
                     aria-label="{{#str}}completionstars, format_minimoodlewall, {{completedcount}}{{/str}}">
                </div>
                {{/enablecompletionstars}}
            </div>
            {{! No activities message - shown when filters result in 0 items }}
            <div class="completion-status-empty" data-region="no-activities" hidden>
                <span>{{#str}}noactivitiesfound, format_minimoodlewall{{/str}}</span>
            </div>
        </div>
        {{/completionstatus}}
        </div>{{! /.mmw-bgdesign-wrapper }}
        {{/cmlist}}
    {{/ core_courseformat/local/content/section/cmlist }}
{{/ core_courseformat/local/content/section }}

{{#js}}
require(['format_minimoodlewall/activity_pagination'], function(pagination) {
    pagination.init();
});
require(['format_minimoodlewall/activity_dragdrop'], function(dragdrop) {
    dragdrop.init();
});
require(['format_minimoodlewall/tag_filter'], function(filter) {
    filter.init();
});
{{/js}}
