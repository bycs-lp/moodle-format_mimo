{{!
    @template format_mimo/local/content/section

    Displays a course section as a minimal wall showing all activities.

    This template extends the core section template.

    Example context (json):
    {
        "num": 3,
        "id": 35,
        "sectionname": "Section title",
        "header": {
            "name": "Section title",
            "title": "<a href=\"#\">Section title</a>",
            "headinglevel": 3
        },
        "cmlist": {
            "cms": [
                {
                    "cmitem": {
                        "cmformat": {
                            "cmname": "<a class=\"aalink\" href=\"#\"><span class=\"instancename\">Forum example</span></a>",
                            "hasname": "true"
                        },
                        "id": 3,
                        "module": "forum",
                        "extraclasses": ""
                    }
                }
            ],
            "hascms": true,
            "activitycount": 1,
            "initialpaginationthreshold": 12,
            "hasinitialnext": false
        },
        "filterbar": {
            "hasitems": true,
            "label": "Filter activities",
            "styleclass": "",
            "isediting": false,
            "emptylabel": "No activities",
            "tags": [
                {
                    "id": 1,
                    "name": "Tag 1",
                    "hasactivities": true,
                    "bgcolor": "#3366cc",
                    "imageurl": ""
                }
            ]
        },
        "completionstatus": {
            "completedcount": 1,
            "incompletecount": 2,
            "allcomplete": false,
            "total": 3
        },
        "styleclass": "",
        "stylevariant": "default",
        "bgdesignclass": "",
        "ishidden": false,
        "iscurrent": true,
        "sectionreturnnum": 0,
        "contentcollapsed": false,
        "insertafter": false,
        "numsections": 5
    }
}}
{{< core_courseformat/local/content/section }}
    {{! Override the cmlist block to display activities in a custom wall format. }}
    {{$ core_courseformat/local/content/section/cmlist }}
        {{! Live region for filter status announcements }}
        <div class="sr-only" role="status" aria-live="polite" aria-atomic="true" data-region="filter-status"></div>
        {{! Live region for pagination status announcements }}
        <div class="sr-only" role="status" aria-live="polite" aria-atomic="true" data-region="pagination-status"></div>
        {{! Background design wrapper — applies theme class to filter bar, board and navigation. }}
        <div class="mimo-bgdesign-wrapper{{#bgdesignclass}} {{bgdesignclass}}{{/bgdesignclass}}">
        {{#filterbar.hasitems}}
        <div class="mimo-filterbar {{styleclass}} {{filterbar.styleclass}}" data-region="mimo-filterbar" data-testid="filter-bar" role="toolbar" aria-label="{{filterbar.label}}" data-style="{{stylevariant}}">
            {{#filterbar.tags}}
            <button
                type="button"
                class="mimo-filterbar-button is-empty"
                data-action="tag-filter"
                data-testid="filter-button"
                data-tagid="{{id}}"
                data-tag-name="{{name}}"
                data-hasactivities="{{#hasactivities}}1{{/hasactivities}}{{^hasactivities}}0{{/hasactivities}}"
                aria-pressed="false"
                title="{{name}}{{^hasactivities}}{{#filterbar.isediting}} · {{filterbar.emptylabel}}{{/filterbar.isediting}}{{/hasactivities}}"
                style="{{#bgcolor}}--mimo-filter-accent: {{bgcolor}};{{/bgcolor}}"
                disabled
            >
                <span class="sr-only">{{#str}}filterby, format_mimo{{/str}} {{name}}</span>
                <span class="mimo-filterbar-symbol">
                    {{#imageurl}}
                    <img src="{{imageurl}}" alt="{{name}}">
                    {{/imageurl}}
                    <span class="mimo-filterbar-label">{{name}}</span>
                </span>
            </button>
            {{/filterbar.tags}}
        </div>
        {{/filterbar.hasitems}}
        {{#cmlist}}
        <ul class="section m-0 mimo-activities row g-3 {{styleclass}}{{#bgdesignclass}} {{bgdesignclass}}{{/bgdesignclass}}{{#hasinitialnext}} pagination-active{{/hasinitialnext}}" data-for="cmlist" data-style="{{stylevariant}}" style="list-style: none;">
            {{#cms}}
            {{#cmitem}}
                {{$ core_courseformat/local/content/section/cmitem}}
                    {{> format_mimo/local/content/section/cmitem}}
                {{/ core_courseformat/local/content/section/cmitem}}
            {{/cmitem}}
            {{/cms}}
        </ul>
        <div class="mimo-navigation-wrapper {{styleclass}}" data-style="{{stylevariant}}" role="navigation" aria-label="{{#str}}paginationnavigation, format_mimo{{/str}}">
            {{! Pagination navigation }}
            <div
                class="mimo-navigation justify-content-end align-items-center gap-3 is-booting"
                data-activity-count="{{activitycount}}"
                data-placeholder-threshold="{{initialpaginationthreshold}}"
                data-has-next="{{#hasinitialnext}}1{{/hasinitialnext}}{{^hasinitialnext}}0{{/hasinitialnext}}"
            >
                <button
                    type="button"
                    id="mimo-prev"
                    class="mimo-nav-btn mimo-nav-btn--prev"
                    aria-label="{{#str}}previouspage, format_mimo{{/str}}"
                    aria-disabled="true"
                    disabled
                >
                    <svg class="mimo-nav-arrow" viewBox="0 0 32 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M14 4L5.5 12L14 20V16H26.5V8H14V4Z" stroke="currentColor" stroke-width="0.3" stroke-linejoin="round"/>
                    </svg>
                </button>
                <button
                    type="button"
                    id="mimo-next"
                    class="mimo-nav-btn mimo-nav-btn--next"
                    aria-label="{{#str}}nextpage, format_mimo{{/str}}"
                    aria-disabled="true"
                    disabled
                >
                    <svg class="mimo-nav-arrow" viewBox="0 0 32 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M18 4L26.5 12L18 20V16H5.5V8H18V4Z" stroke="currentColor" stroke-width="0.3" stroke-linejoin="round"/>
                    </svg>
                </button>
            </div>
        </div>
        {{#completionstatus}}
        {{! Completion status indicator region }}
        <div class="mimo-completion-status {{styleclass}}" data-region="completion-status" data-style="{{stylevariant}}">
            {{! Active tag image overlay - shown when tag filter is active }}
            <div class="completion-status-tag-image" data-region="active-tag-image" hidden>
                <img src="" alt="" class="completion-status-tag-img">
            </div>
            {{! Completion filter pills }}
            <div class="completion-status-pills" role="group" aria-label="{{#str}}completionfilter, format_mimo{{/str}}">
                <button
                    type="button"
                    class="completion-pill completion-pill--complete"
                    data-action="completion-filter"
                    data-completed="true"
                    aria-pressed="false"
                    aria-label="{{#str}}showcompletedactivities, format_mimo{{/str}}"
                >
                    <span class="completion-pill-icon" aria-hidden="true">
                        <i class="fa fa-check"></i>
                    </span>
                    <span class="completion-pill-count" data-count="completed">{{completedcount}}</span>
                </button>
                <button
                    type="button"
                    class="completion-pill completion-pill--incomplete"
                    data-action="completion-filter"
                    data-completed="false"
                    aria-pressed="false"
                    aria-label="{{#str}}showincompleteactivities, format_mimo{{/str}}"
                >
                    <span class="completion-pill-icon" aria-hidden="true">
                        <i class="fa fa-hourglass"></i>
                    </span>
                    <span class="completion-pill-count" data-count="incomplete">{{incompletecount}}</span>
                </button>
                {{! Sparkle star - shown when all tracked activities are complete. }}
                <div class="completion-stars{{#allcomplete}} is-visible{{/allcomplete}}"
                     data-region="completion-stars"
                     data-completed-count="{{completedcount}}"
                     data-total-count="{{total}}"
                     role="img"
                     aria-label="{{#str}}completionstars, format_mimo, {{completedcount}}{{/str}}">
                    <span class="star-rays" aria-hidden="true"></span>
                    <span class="star-icon" aria-hidden="true"><i class="fa fa-star"></i></span>
                    <span class="star-sparkles" aria-hidden="true"></span>
                    <span class="star-sparkle-dot" aria-hidden="true">✦</span>
                    <span class="star-sparkle-dot" aria-hidden="true">✦</span>
                </div>
            </div>
            {{! No activities message - shown when filters result in 0 items }}
            <div class="completion-status-empty" data-region="no-activities" hidden>
                <span>{{#str}}noactivitiesfound, format_mimo{{/str}}</span>
            </div>
        </div>
        {{/completionstatus}}
        </div>{{! /.mimo-bgdesign-wrapper }}
        {{/cmlist}}
    {{/ core_courseformat/local/content/section/cmlist }}
{{/ core_courseformat/local/content/section }}

{{#js}}
require(['format_mimo/init_courseeditor_watcher'], function(watcher) {
    watcher.init();
});
require(['format_mimo/activity_pagination'], function(pagination) {
    pagination.init();
});
require(['format_mimo/activity_dragdrop'], function(dragdrop) {
    dragdrop.init();
});
require(['format_mimo/tag_filter'], function(filter) {
    filter.init();
});
{{/js}}
