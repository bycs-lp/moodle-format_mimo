{{!
    @template format_minimoodlewall/local/content/section

    Displays a course section as a minimal wall showing all activities.

    This template extends the core section template.
}}
{{< core_courseformat/local/content/section }}
    {{! Override the cmlist block to display activities in a custom wall format. }}
    {{$ core_courseformat/local/content/section/cmlist }}
        {{#cmlist}}
        <div class="minimoodlewall-activities">
            <div class="row g-3">
                {{#cms}}
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="minimoodlewall-card card h-100" data-cmid="{{id}}">
                        {{! Tag Image at top }}
                        <div class="minimoodlewall-card-image">
                            {{#cmitem}}
                            {{#cmformat}}
                            {{#tagimage}}
                            <img src="{{tagimage}}" alt="{{tagname}}" class="w-100">
                            {{/tagimage}}
                            {{^tagimage}}
                            <div class="minimoodlewall-card-placeholder"></div>
                            {{/tagimage}}
                            {{/cmformat}}
                            {{/cmitem}}
                        </div>
                        
                        {{! Completion indicator overlay (top-right) }}
                        <div class="minimoodlewall-completion-badge">
                            {{#cmitem}}
                            {{#cmformat}}
                            {{#completion}}
                            {{#hascompletion}}
                            {{#iscomplete}}
                            <span class="badge-complete" title="{{#str}}completed, format_minimoodlewall{{/str}}">
                                <i class="fa fa-check-circle"></i>
                            </span>
                            {{/iscomplete}}
                            {{^iscomplete}}
                            <span class="badge-incomplete" title="{{#str}}notcompleted, format_minimoodlewall{{/str}}">
                                <i class="fa fa-circle"></i>
                            </span>
                            {{/iscomplete}}
                            {{/hascompletion}}
                            {{/completion}}
                            {{/cmformat}}
                            {{/cmitem}}
                        </div>
                        
                        {{! Card body with description }}
                        <div class="card-body minimoodlewall-card-body">
                            {{#cmitem}}
                            {{#cmformat}}
                            {{! Activity title (visible on hover via CSS) }}
                            <div class="minimoodlewall-card-title">
                                {{#url}}
                                <a href="{{url}}" class="activity-link stretched-link">
                                    {{activityname}}
                                </a>
                                {{/url}}
                                {{^url}}
                                {{activityname}}
                                {{/url}}
                            </div>
                            
                            {{! Description preview (3 lines max) }}
                            {{#description}}
                            <div class="minimoodlewall-card-description text-muted small">
                                {{{description}}}
                            </div>
                            {{/description}}
                            {{/cmformat}}
                            {{/cmitem}}
                        </div>
                    </div>
                </div>
                {{/cms}}
            </div>
        </div>
        {{/cmlist}}
    {{/ core_courseformat/local/content/section/cmlist }}
{{/ core_courseformat/local/content/section }}
