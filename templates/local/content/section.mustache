{{!
    @template format_minimoodlewall/local/content/section

    Displays a course section as a minimal wall showing all activities.

    This template extends the core section template.
}}
{{< core_courseformat/local/content/section }}
    {{! Override the cmlist block to display activities in a custom wall format. }}
    {{$ core_courseformat/local/content/section/cmlist }}
        {{#cmlist}}
        <div class="minimoodlewall-activities">
            <div class="row g-3">
                {{#cms}}
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="card h-100">
                        <div class="card-body">
                            {{#cmitem}}
                            {{#cmformat}}
                            
                            {{! Activity Name/Link - using activityname and url since cmname.displayvalue is empty }}
                            {{#hasname}}
                            <div class="activity-name mb-3">
                                {{#url}}
                                <a href="{{url}}" class="activity-link">
                                    <strong>{{activityname}}</strong>
                                </a>
                                {{/url}}
                                {{^url}}
                                <strong>{{activityname}}</strong>
                                {{/url}}
                            </div>
                            {{/hasname}}
                            
                            {{! Module type badge }}
                            <div class="activity-type mb-2">
                                <span class="badge bg-secondary">{{modname}}</span>
                            </div>
                            
                            {{! Activity Badge (e.g. file type for resources) }}
                            {{#activitybadge}}
                            <div class="activity-badge mb-2">
                                <span class="badge {{badgestyle}}">{{badgecontent}}</span>
                            </div>
                            {{/activitybadge}}
                            
                            {{! Description/Alt content }}
                            {{#altcontent}}
                            <div class="activity-description text-muted small mt-2">
                                {{{altcontent}}}
                            </div>
                            {{/altcontent}}
                            
                            {{! After link info (e.g. file size, dates) }}
                            {{#afterlink}}
                            <div class="activity-afterlink text-muted small mt-2">
                                {{{afterlink}}}
                            </div>
                            {{/afterlink}}
                            
                            {{! Completion status }}
                            {{#completion}}
                            {{#hascompletion}}
                            <div class="activity-completion mt-2">
                                {{> core_courseformat/local/content/cm/activity_info}}
                            </div>
                            {{/hascompletion}}
                            {{/completion}}
                            
                            {{/cmformat}}
                            {{/cmitem}}
                        </div>
                    </div>
                </div>
                {{/cms}}
            </div>
        </div>
        {{/cmlist}}
    {{/ core_courseformat/local/content/section/cmlist }}
{{/ core_courseformat/local/content/section }}
