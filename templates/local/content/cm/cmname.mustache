{{!
    @template format_mimo/local/content/cm/cmname

    Custom activity name display for mimo format with stretched link support.

    Example context (json):
    {
        "url": "http://example.com/mod/forum/view.php?id=3",
        "textclasses": "",
        "modname": "forum",
        "activityname": {
            "displayvalue": "Forum example"
        }
    }
}}
{{#url}}
    {{! Name with inplace editing and stretched link }}
    <div class="activity-name-area activity-instance">
        <div class="activitytitle {{textclasses}} modtype_{{modname}}">
            <div class="activityname">
                {{#activityname}}
                    {{! Custom inplace editable with stretched-link preserved }}
                    {{#component}}
                    <span class="inplaceeditable inplaceeditable-{{type}}" data-inplaceeditable="1" data-component="{{component}}" data-itemtype="{{itemtype}}" data-itemid="{{itemid}}"
                        data-value="{{value}}" data-editlabel="{{editlabel}}" data-type="{{type}}" data-options="{{options}}">
                            {{{displayvalue}}}
                            <a href="#" class="quickeditlink aalink" data-inplaceeditablelink="1" title="{{edithint}}">
                                <span class="quickediticon visibleifjs icon-size-3">
                                    {{#editicon}}{{#pix}}{{key}}, {{component}}, {{{title}}}{{/pix}}{{/editicon}}
                                </span>
                            </a>
                    </span>
                    {{#js}}
                        require(['core/inplace_editable']);
                    {{/js}}
                    {{/component}}
                    {{^component}}
                        {{{displayvalue}}}
                    {{/component}}
                {{/activityname}}
            </div>
        </div>
    </div>
{{/url}}
