{{!
    @template format_minimoodlewall/style_management

    Style management page template.

    Context variables:
    * createstyleurl - URL to create new style
    * createstyletext - Text for create style button
    * nostylestext - Text when no styles exist
    * hasstyles - Boolean if styles exist
    * tableheaders - Object with table header strings
    * styles - Array of style objects

    Example context (json):
    {
        "createstyleurl": "/path/to/create",
        "createstyletext": "Create style",
        "hasstyles": true,
        "tableheaders": {
            "name": "Name",
            "displayname": "Display name",
            "sortorder": "Sort order",
            "actions": "Actions"
        },
        "styles": [
            {
                "id": 1,
                "name": "classic",
                "displayname": "Classic",
                "sortorder": 1,
                "editurl": "/path/to/edit",
                "deleteurl": "/path/to/delete",
                "edittitle": "Edit style",
                "deletetitle": "Delete style"
            }
        ]
    }
}}

<div class="style-management" data-region="style-management">
    <div class="mb-3">
        <a href="{{createstyleurl}}" class="btn btn-primary" data-testid="create-style-button">
            {{createstyletext}}
        </a>
    </div>

    {{^hasstyles}}
        <div class="alert alert-info">
            {{nostylestext}}
        </div>
    {{/hasstyles}}

    {{#hasstyles}}
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped generaltable" data-testid="style-list-table">
                        <thead>
                            <tr>
                                <th>{{tableheaders.name}}</th>
                                <th>{{tableheaders.displayname}}</th>
                                <th>{{tableheaders.sortorder}}</th>
                                <th>{{tableheaders.actions}}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#styles}}
                                <tr data-testid="style-row" data-style-id="{{id}}" data-style-name="{{name}}">
                                    <td><code>{{name}}</code></td>
                                    <td>{{displayname}}</td>
                                    <td>{{sortorder}}</td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <a href="{{editurl}}" title="{{edittitle}}" class="btn btn-sm btn-icon" data-testid="edit-style-button">
                                                {{#pix}}i/edit, core, {{edittitle}}{{/pix}}
                                            </a>
                                            <a href="{{deleteurl}}"
                                               title="{{deletetitle}}"
                                               class="btn btn-sm btn-icon"
                                               data-action="delete-style"
                                               data-testid="delete-style-button"
                                               data-style-id="{{id}}"
                                               data-style-name="{{name}}">
                                                {{#pix}}t/delete, core, {{deletetitle}}{{/pix}}
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {{/styles}}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    {{/hasstyles}}
</div>
