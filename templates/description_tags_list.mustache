{{!
    @template format_minimoodlewall/description_tags_list

    Description tag list for management page.

    Context variables required for this template:
    * createurl - URL to create new tag
    * tags - Array of tag objects
    * notags - Boolean, true if no tags exist

    Example context (json):
    {
        "createurl": "http://example.com/create",
        "tags": [
            {
                "name": "Assessment",
                "color": "#FF5733",
                "usagecount": 5,
                "editurl": "http://example.com/edit?id=1",
                "deleteurl": "http://example.com/delete?id=1",
                "editicon": "<svg>...</svg>",
                "deleteicon": "<svg>...</svg>"
            }
        ],
        "notags": false
    }
}}

<div class="description-tags-management">
    <div class="mb-3">
        <a href="{{{createurl}}}" class="btn btn-primary">
            {{#str}}createdesctag, format_minimoodlewall{{/str}}
        </a>
    </div>

    {{#notags}}
        <div class="alert alert-info">
            {{#str}}nodesctags, format_minimoodlewall{{/str}}
        </div>
    {{/notags}}

    {{^notags}}
        <table class="table table-striped generaltable">
            <thead>
                <tr>
                    <th>{{#str}}desctagname, format_minimoodlewall{{/str}}</th>
                    <th>{{#str}}desctagcolor, format_minimoodlewall{{/str}}</th>
                    <th>{{#str}}usage, format_minimoodlewall{{/str}}</th>
                    <th>{{#str}}actions{{/str}}</th>
                </tr>
            </thead>
            <tbody>
                {{#tags}}
                <tr>
                    <td>{{name}}</td>
                    <td>
                        <span class="color-preview" style="display:inline-block;width:30px;height:20px;background-color:{{color}};border:1px solid #ccc;vertical-align:middle;"></span>
                        <span class="ml-2">{{color}}</span>
                    </td>
                    <td>{{usagecount}}</td>
                    <td>
                        <a href="{{{editurl}}}" title="{{#str}}edit{{/str}}">
                            {{{editicon}}}
                        </a>
                        <a href="{{{deleteurl}}}" class="ml-2" title="{{#str}}delete{{/str}}">
                            {{{deleteicon}}}
                        </a>
                    </td>
                </tr>
                {{/tags}}
            </tbody>
        </table>
    {{/notags}}
</div>
