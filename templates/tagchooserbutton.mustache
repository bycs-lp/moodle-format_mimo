{{!
    @template format_minimoodlewall/tagchooserbutton

    Displays a tag-based content chooser button with dropdown.

    Example context (json):
    {
        "tags": [
            {
                "id": 1,
                "name": "Reading",
                "activitytype1": "resource",
                "activitytype2": null
            }
        ],
        "sectionnum": 0,
        "modid": 1,
        "activityname": "Activity example",
        "sectionreturn": 0,
        "uniqid": "abc123"
    }
}}
<div class="dropdown format-minimoodlewall-tagchooser">
    <button class="btn add-content d-flex justify-content-center align-items-center p-1 icon-no-margin"
            type="button"
            id="tagChooserButton-{{#modid}}{{modid}}{{/modid}}{{^modid}}{{uniqid}}{{/modid}}"
            data-bs-toggle="dropdown"
            data-action="open-tagchooser"
            data-sectionnum="{{sectionnum}}"
            {{#sectionreturn}}data-sectionreturnnum="{{sectionreturn}}"{{/sectionreturn}}
            {{#modid}}
            data-beforemod="{{modid}}"
            aria-label="{{#str}}insertcontentbefore, core, { "activityname": {{#quote}} {{activityname}} {{/quote}} } {{/str}}"
            {{/modid}}
            {{^modid}}
            aria-label="{{#str}}addcontent, core{{/str}}"
            {{/modid}}
            aria-haspopup="true"
            aria-expanded="false"
            tabindex="0"
            title="{{#str}}addcontent, core{{/str}}"
    >
        {{#pix}} t/add, core {{/pix}}
    </button>
    <div class="dropdown-menu" aria-labelledby="tagChooserButton-{{#modid}}{{modid}}{{/modid}}{{^modid}}{{uniqid}}{{/modid}}">
        {{#tags}}
            <a href="#"
               class="dropdown-item format-minimoodlewall-tag-link"
               data-tag-id="{{id}}"
               data-tag-name="{{name}}"
               data-activity-type1="{{activitytype1}}"
               data-activity-type2="{{activitytype2}}"
               data-activity-type3="{{activitytype3}}"
               data-sectionnum="{{sectionnum}}"
               {{#modid}}data-beforemod="{{modid}}"{{/modid}}
               {{#sectionreturn}}data-sectionreturnnum="{{sectionreturn}}"{{/sectionreturn}}
            >
                {{name}}
            </a>
        {{/tags}}
    </div>
</div>
