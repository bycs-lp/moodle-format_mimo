{{!
    @template format_minimoodlewall/form_tag_option

    Renders a tag option for the course form with inline image.

    Example context (json):
    {
        "name": "Lesen",
        "imageurl": "https://example.com/pluginfile.php/1/format_minimoodlewall/tagcard/1/reading.svg",
        "tagid": 1,
        "styleimages": "{\"classic\":\"https://...\",\"dark\":\"https://...\"}"
    }
}}
<span class="mmw-tag-option d-flex align-items-center" data-tagid="{{tagid}}" data-styleimages="{{styleimages}}">
    {{#imageurl}}
    <img src="{{imageurl}}" class="mmw-tag-preview me-2" data-tagimage="{{tagid}}" alt="" aria-hidden="true">
    {{/imageurl}}
    {{^imageurl}}
    <span class="mmw-tag-preview-placeholder me-2" data-tagimage="{{tagid}}"></span>
    {{/imageurl}}
    <span class="mmw-tag-name">{{name}}</span>
</span>
