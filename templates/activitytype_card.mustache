{{!
    @template format_minimoodlewall/activitytype_card

    Activity type card partial template.

    Context variables required for this template:
    * activitytype - Activity module type (e.g., 'assign', 'quiz')
    * label - Activity type label (e.g., 'Assignment')
    * description - Activity type description
    * icon - Icon HTML
    * purpose - Purpose CSS class (e.g., 'assessment', 'administration')
    * type - Type string (e.g., 'Activity type')

    Example context (json):
    {
        "activitytype": "assign",
        "label": "Assignment",
        "description": "Create an assignment...",
        "icon": "<img src='...' alt='Assignment'>",
        "purpose": "assessment",
        "type": "Activity type"
    }
}}
<a href="#" class="mmw-activity-card" data-activity-type="{{activitytype}}">
    <div class="mmw-activity-card-content">
        <h3 class="mmw-activity-card-title">{{label}}</h3>
        <p class="mmw-activity-card-description">{{description}}</p>
        <div class="mmw-activity-card-icon activityiconcontainer {{purpose}} modicon_{{activitytype}}">
            {{{icon}}}
        </div>
    </div>
</a>
