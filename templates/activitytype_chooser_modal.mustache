{{!
    @template format_minimoodlewall/activitytype_chooser_modal

    Activity type chooser modal body template.

    Context variables required for this template:
    * selectactivitytype - Prompt text for selecting activity type
    * activitytype1 - First activity type option
    * activitytype1label - Label for first activity type
    * hasactivitytype1 - Whether first activity type exists
    * activitytype2 - Second activity type option
    * activitytype2label - Label for second activity type
    * hasactivitytype2 - Whether second activity type exists
    * activityorresource - Label for activity chooser option

    Example context (json):
    {
        "selectactivitytype": "Select activity type...",
        "activitytype1": "assign",
        "activitytype1label": "Assignment",
        "hasactivitytype1": true,
        "activitytype2": "quiz",
        "activitytype2label": "Quiz",
        "hasactivitytype2": true,
        "activityorresource": "Activity or resource"
    }
}}
<div class="format-minimoodlewall-activity-options">
    <p class="mb-3 fw-bold">{{selectactivitytype}}</p>
    <p class="mb-4 text-muted">{{selectactivitytypedesc}}</p>
    <div class="row g-3 mb-3">
        {{#hasactivitytype1}}
        <div class="col-6">
            <a href="#" class="mmw-activity-card" data-activity-type="{{activitytype1}}">
                <div class="mmw-activity-card-content">
                    <h3 class="mmw-activity-card-title">{{activitytype1label}}</h3>
                    <p class="mmw-activity-card-description">{{activitytype1description}}</p>
                    <p class="mmw-activity-card-type">{{activitytype1type}}</p>
                    <div class="mmw-activity-card-icon">
                        {{{activitytype1icon}}}
                    </div>
                </div>
            </a>
        </div>
        {{/hasactivitytype1}}
        {{#hasactivitytype2}}
        <div class="col-6">
            <a href="#" class="mmw-activity-card" data-activity-type="{{activitytype2}}">
                <div class="mmw-activity-card-content">
                    <h3 class="mmw-activity-card-title">{{activitytype2label}}</h3>
                    <p class="mmw-activity-card-description">{{activitytype2description}}</p>
                    <p class="mmw-activity-card-type">{{activitytype2type}}</p>
                    <div class="mmw-activity-card-icon">
                        {{{activitytype2icon}}}
                    </div>
                </div>
            </a>
        </div>
        {{/hasactivitytype2}}
    </div>
    <div class="row">
        <div class="col-12">
            <a href="#" class="mmw-activity-chooser-link" data-activity-type="chooser">
                {{activityorresource}}
            </a>
        </div>
    </div>
</div>
