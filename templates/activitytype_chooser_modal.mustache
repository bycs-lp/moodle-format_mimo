{{!
    @template format_minimoodlewall/activitytype_chooser_modal

    Activity type chooser modal body template.

    Context variables required for this template:
    * selectactivitytype - Prompt text for selecting activity type
    * activitytype1 - First activity type option
    * activitytype1label - Label for first activity type
    * hasactivitytype1 - Whether first activity type exists
    * activitytype2 - Second activity type option
    * activitytype2label - Label for second activity type
    * hasactivitytype2 - Whether second activity type exists
    * activityorresource - Label for activity chooser option

    Example context (json):
    {
        "selectactivitytype": "Select activity type...",
        "activitytype1": "assign",
        "activitytype1label": "Assignment",
        "hasactivitytype1": true,
        "activitytype2": "quiz",
        "activitytype2label": "Quiz",
        "hasactivitytype2": true,
        "activityorresource": "Activity or resource"
    }
}}
<div class="format-minimoodlewall-activity-options">
    <p class="mb-3">{{selectactivitytype}}</p>
    <div class="row g-2 mb-2">
        {{#hasactivitytype1}}
        <div class="col-6">
            <a href="#" class="list-group-item list-group-item-action activity-type-option h-100 d-flex align-items-center justify-content-center text-center p-4" data-activity-type="{{activitytype1}}">
                <strong>{{activitytype1label}}</strong>
            </a>
        </div>
        {{/hasactivitytype1}}
        {{#hasactivitytype2}}
        <div class="col-6">
            <a href="#" class="list-group-item list-group-item-action activity-type-option h-100 d-flex align-items-center justify-content-center text-center p-4" data-activity-type="{{activitytype2}}">
                <strong>{{activitytype2label}}</strong>
            </a>
        </div>
        {{/hasactivitytype2}}
    </div>
    <div class="row">
        <div class="col-12">
            <a href="#" class="list-group-item list-group-item-action activity-type-option d-flex align-items-center justify-content-center p-3" data-activity-type="chooser">
                <i class="icon fa fa-plus fa-fw me-2"></i> <strong>{{activityorresource}}</strong>
            </a>
        </div>
    </div>
</div>
