{{!
    @template format_minimoodlewall/activitytype_chooser_modal

    Activity type chooser modal body template.

    Context variables required for this template:
    * selectactivitytype - Prompt text for selecting activity type
    * selectactivitytypedesc - Description text for the chooser
    * activitycards - Array of activity card objects with properties:
        - activitytype: Activity module type
        - label: Activity type label
        - description: Activity type description
        - icon: Icon HTML
        - purpose: Purpose CSS class
        - type: Type string
    * colclass - Bootstrap column class (e.g., 'col-4', 'col-6')
    * activityorresource - Label for activity chooser option

    Example context (json):
    {
        "selectactivitytype": "Select activity type...",
        "selectactivitytypedesc": "Choose which type...",
        "activitycards": [
            {
                "activitytype": "assign",
                "label": "Assignment",
                "description": "Create an assignment...",
                "icon": "<img src='...' alt='Assignment'>",
                "purpose": "assessment",
                "type": "Activity type"
            }
        ],
        "colclass": "col-6",
        "activityorresource": "Activity or resource"
    }
}}
<div class="format-minimoodlewall-activity-options">
    <p class="mb-0 fs-5">{{selectactivitytype}}</p>
    <p class="mb-4 text-muted">{{selectactivitytypedesc}}</p>
    <div class="row g-3 mb-3">
        {{#activitycards}}
        <div class="{{colclass}}">
            {{> format_minimoodlewall/activitytype_card }}
        </div>
        {{/activitycards}}
    </div>
    <div class="row">
        <div class="col-12">
            <a href="#" class="mmw-activity-chooser-link" data-activity-type="chooser">
                {{activityorresource}}
            </a>
        </div>
    </div>
</div>
