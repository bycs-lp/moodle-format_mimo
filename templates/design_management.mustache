{{!
    @template format_minimoodlewall/design_management

    Design management page template.

    Context variables:
    * createdesignurl - URL to create new design
    * createdesigntext - Text for create design button
    * nodesignstext - Text when no designs exist
    * hasdesigns - Boolean if designs exist
    * tableheaders - Object with table header strings
    * designs - Array of design objects

    Example context (json):
    {
        "createdesignurl": "/path/to/create",
        "createdesigntext": "Create design",
        "hasdesigns": true,
        "tableheaders": {
            "name": "Name",
            "displayname": "Display name",
            "sortorder": "Sort order",
            "actions": "Actions"
        },
        "designs": [
            {
                "id": 1,
                "name": "classic",
                "displayname": "Classic",
                "sortorder": 1,
                "editurl": "/path/to/edit",
                "deleteurl": "/path/to/delete",
                "edittitle": "Edit design",
                "deletetitle": "Delete design"
            }
        ]
    }
}}

<div class="design-management" data-region="design-management">
    <div class="mb-3">
        <a href="{{createdesignurl}}" class="btn btn-primary" data-testid="create-design-button">
            {{createdesigntext}}
        </a>
    </div>

    {{^hasdesigns}}
        <div class="alert alert-info">
            {{nodesignstext}}
        </div>
    {{/hasdesigns}}

    {{#hasdesigns}}
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped generaltable" data-testid="design-list-table">
                        <thead>
                            <tr>
                                <th>{{tableheaders.name}}</th>
                                <th>{{tableheaders.displayname}}</th>
                                <th>{{tableheaders.sortorder}}</th>
                                <th>{{tableheaders.actions}}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#designs}}
                                <tr data-testid="design-row" data-design-id="{{id}}" data-design-name="{{name}}">
                                    <td><code>{{name}}</code></td>
                                    <td>{{displayname}}</td>
                                    <td>{{sortorder}}</td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <a href="{{editurl}}" title="{{edittitle}}" class="btn btn-sm btn-icon" data-testid="edit-design-button">
                                                {{#pix}}i/edit, core, {{edittitle}}{{/pix}}
                                            </a>
                                            <a href="{{deleteurl}}"
                                               title="{{deletetitle}}"
                                               class="btn btn-sm btn-icon"
                                               data-action="delete-design"
                                               data-testid="delete-design-button"
                                               data-design-id="{{id}}"
                                               data-design-name="{{name}}">
                                                {{#pix}}t/delete, core, {{deletetitle}}{{/pix}}
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {{/designs}}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    {{/hasdesigns}}
</div>
