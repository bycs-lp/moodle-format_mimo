{{!
    @template format_minimoodlewall/form_tag_preview

    Renders a read-only preview of tags enabled for the selected activity profile.
    Displayed in the course settings form below the activity profile dropdown.

    Example context (json):
    {
        "tags": [
            {
                "name": "Lesen",
                "imageurl": "https://example.com/pluginfile.php/1/format_minimoodlewall/tagcard/1/reading.svg",
                "tagid": 1,
                "profileimages": "{\"classic\":\"https://...\",\"dark\":\"https://...\"}",
                "profilenames": "{\"classic\":\"Lesen\",\"dark\":\"Reading\"}",
                "profileenabled": "{\"classic\":1,\"dark\":0}"
            }
        ],
        "label": "Active tags"
    }
}}
<div class="mmw-tag-preview-container d-flex flex-wrap gap-3 mt-2">
    {{#tags}}
    <div class="mmw-tag-preview-item d-flex align-items-center" data-tagid="{{tagid}}"
         data-profileimages="{{profileimages}}" data-profilenames="{{profilenames}}" data-profileenabled="{{profileenabled}}">
        {{#imageurl}}
        <img src="{{imageurl}}" class="mmw-tag-preview-img me-2" data-tagimage="{{tagid}}" alt="" aria-hidden="true">
        {{/imageurl}}
        {{^imageurl}}
        <span class="mmw-tag-preview-placeholder me-2" data-tagimage="{{tagid}}"></span>
        {{/imageurl}}
        <span class="mmw-tag-name">{{name}}</span>
    </div>
    {{/tags}}
</div>
