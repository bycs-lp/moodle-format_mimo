{{!
    @template format_minimoodlewall/tag_management

    Tag management page template with collapsible tagset sections.

    Context variables:
    * createtagseturl - URL to create new tagset
    * createtagsettext - Text for create tagset button
    * notagsetstext - Text when no tagsets exist
    * notagstext - Text when no tags exist in a tagset
    * hastagsets - Boolean if tagsets exist
    * tableheaders - Object with table header strings
    * tagsets - Array of tagset objects
}}

<div class="tag-management" data-region="tag-management">
    <div class="mb-3">
        <a href="{{createtagseturl}}" class="btn btn-primary" data-testid="create-tagset-button">
            {{createtagsettext}}
        </a>
    </div>

    {{^hastagsets}}
        <div class="alert alert-info">
            {{notagsetstext}}
        </div>
    {{/hastagsets}}

    {{#hastagsets}}
        <div class="accordion" id="tagset-accordion">
            {{#tagsets}}
                <div class="accordion-item mb-3" data-tagset-id="{{id}}" data-tagset-name="{{name}}">
                    <h2 class="accordion-header position-relative w-100" id="tagset-heading-{{id}}">
                        <button class="accordion-button collapsed" type="button"
                                data-bs-toggle="collapse" data-bs-target="#tagset-collapse-{{id}}"
                                aria-expanded="false" aria-controls="tagset-collapse-{{id}}">
                            <span class="fw-bold">{{name}}</span>
                            {{#description}}
                                <span class="text-muted ms-2 small">— {{description}}</span>
                            {{/description}}
                        </button>
                        <div class="d-flex gap-2 position-absolute" style="right: 3.5rem; top: 50%; transform: translateY(-50%); z-index: 100; pointer-events: auto;">
                            <a href="{{edittagseturl}}" title="{{edittagsettitle}}" class="btn btn-sm btn-icon"
                               data-testid="edit-tagset-button" onclick="event.stopPropagation();"
                               style="position: relative; z-index: 100;">
                                {{#pix}}i/edit, core, {{edittagsettitle}}{{/pix}}
                            </a>
                            <a href="{{deletetagseturl}}" title="{{deletetagsettitle}}"
                               class="btn btn-sm btn-icon"
                               data-action="delete-tagset"
                               data-testid="delete-tagset-button"
                               data-tagset-id="{{id}}"
                               data-tagset-name="{{name}}"
                               onclick="event.stopPropagation();"
                               style="position: relative; z-index: 100;">
                                {{#pix}}t/delete, core, {{deletetagsettitle}}{{/pix}}
                            </a>
                        </div>
                    </h2>
                    <div id="tagset-collapse-{{id}}" class="accordion-collapse collapse"
                         aria-labelledby="tagset-heading-{{id}}" data-bs-parent="#tagset-accordion">
                        <div class="accordion-body">
                            <div class="mb-3">
                                <a href="{{createtagurl}}" class="btn btn-outline-primary btn-sm" data-testid="create-tag-button">
                                    {{#str}}createtag, format_minimoodlewall{{/str}}
                                </a>
                            </div>

                            {{^hastags}}
                                <div class="alert alert-info">
                                    {{notagstext}}
                                </div>
                            {{/hastags}}

                            {{#hastags}}
                                <div class="table-responsive">
                                    <table class="table table-striped generaltable" data-testid="tag-list-table">
                                        <thead>
                                            <tr>
                                                <th>{{tableheaders.cardimage}}</th>
                                                <th>{{tableheaders.name}}</th>
                                                <th>{{tableheaders.bgcolor}}</th>
                                                <th>{{tableheaders.activitytype1}}</th>
                                                <th>{{tableheaders.activitytype2}}</th>
                                                <th>{{tableheaders.activitytype3}}</th>
                                                <th>{{tableheaders.actions}}</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {{#tags}}
                                                <tr data-testid="tag-row" data-tag-id="{{id}}" data-tag-name="{{name}}">
                                                    <td>
                                                        {{#cardimageurl}}
                                                            <img src="{{cardimageurl}}"
                                                                 alt="{{name}}"
                                                                 style="width: 80px; height: 50px; object-fit: cover;">
                                                        {{/cardimageurl}}
                                                        {{^cardimageurl}}
                                                            <span class="text-muted">-</span>
                                                        {{/cardimageurl}}
                                                    </td>
                                                    <td>{{name}}</td>
                                                    <td class="align-middle">
                                                        <span style="display:inline-block;width:32px;height:20px;border-radius:6px;background:{{bgcolor}};border:1px solid rgba(0,0,0,0.1);"></span>
                                                        <span class="ms-2 text-muted small fw-semibold">{{bgcolor}}</span>
                                                    </td>
                                                    <td>{{activitytype1}}</td>
                                                    <td>{{activitytype2}}</td>
                                                    <td>{{activitytype3}}</td>
                                                    <td>
                                                        <div class="d-flex gap-2">
                                                            <a href="{{editurl}}" title="{{edittitle}}" class="btn btn-sm btn-icon" data-testid="edit-tag-button">
                                                                {{#pix}}i/edit, core, {{edittitle}}{{/pix}}
                                                            </a>
                                                            <a href="{{deleteurl}}"
                                                               title="{{deletetitle}}"
                                                               class="btn btn-sm btn-icon"
                                                               data-action="delete-tag"
                                                               data-testid="delete-tag-button"
                                                               data-tag-id="{{id}}"
                                                               data-tag-name="{{name}}">
                                                                {{#pix}}t/delete, core, {{deletetitle}}{{/pix}}
                                                            </a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            {{/tags}}
                                        </tbody>
                                    </table>
                                </div>
                            {{/hastags}}
                        </div>
                    </div>
                </div>
            {{/tagsets}}
        </div>
    {{/hastagsets}}
</div>
