{{!
    @template format_mimo/tag_management

    Tag management page template with profile-filtered tag list.

    Context variables:
    * createtagurl - URL to create new tag
    * createtagtext - Text for create tag button
    * notagstext - Text when no tags exist
    * hastags - Boolean if tags exist
    * tableheaders - Object with table header strings
    * profilebuttons - Array of profile button objects (name, displayname, active)
    * tags - Array of tag objects (resolved for active profile)
    * disabledtext - Text for disabled badge
}}

<div class="tag-management" data-region="tag-management"
     data-tag-profile-data="{{tagprofiledatajson}}"
     data-profile-id-map="{{profileidmapjson}}"
     data-current-profile="{{currentprofile}}"
     data-management-url="{{managementurl}}"
     data-active-profile-id="{{activeprofileid}}">
    <div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
        <button type="button" class="btn btn-primary" data-action="create-tag" data-testid="create-tag-button">
            {{createtagtext}}
        </button>
        <span class="mx-2 text-muted">|</span>
        {{#profilebuttons}}
            <span class="d-inline-flex align-items-center gap-1">
                <button type="button"
                        class="btn btn-sm {{#active}}btn-primary{{/active}}{{^active}}btn-secondary{{/active}}"
                        data-action="switch-profile"
                        data-profile-name="{{name}}"
                        data-testid="profile-button-{{name}}">
                    {{displayname}}
                    {{#isimported}}
                        <span class="badge bg-info ms-1">{{importedtext}}</span>
                    {{/isimported}}
                </button>
                {{#promoteurl}}
                    <a href="{{promoteurl}}" class="btn btn-sm btn-outline-success" title="{{promotetoglobaltext}}" data-testid="promote-profile-button">
                        {{#pix}}i/publish, core, {{promotetoglobaltext}}{{/pix}}
                    </a>
                {{/promoteurl}}
            </span>
        {{/profilebuttons}}
    </div>

    {{^hastags}}
        <div class="alert alert-info">
            {{notagstext}}
        </div>
    {{/hastags}}

    {{#hastags}}
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped generaltable" data-testid="tag-list-table">
                        <thead>
                            <tr>
                                <th>{{tableheaders.cardimage}}</th>
                                <th>{{tableheaders.name}}</th>
                                <th>{{tableheaders.bgcolor}}</th>
                                <th>{{tableheaders.activitytype1}}</th>
                                <th>{{tableheaders.activitytype2}}</th>
                                <th>{{tableheaders.activitytype3}}</th>
                                <th>{{tableheaders.actions}}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#tags}}
                                <tr data-testid="tag-row"
                                    data-tag-id="{{id}}"
                                    data-tag-name="{{name}}"
                                    style="cursor: pointer;{{#disabled}} opacity: 0.45;{{/disabled}}">
                                    <td data-field="cardimage">
                                        {{#cardimageurl}}
                                            <img src="{{cardimageurl}}"
                                                 alt="{{name}}"
                                                 style="width: 80px; height: 50px; object-fit: cover;">
                                        {{/cardimageurl}}
                                        {{^cardimageurl}}
                                            <span class="text-muted">-</span>
                                        {{/cardimageurl}}
                                    </td>
                                    <td data-field="name">
                                        {{name}}
                                        {{#disabled}}
                                            <span class="badge bg-secondary ms-1">{{disabledtext}}</span>
                                        {{/disabled}}
                                        {{#isimported}}
                                            <span class="badge bg-info ms-1">{{importedtext}}</span>
                                        {{/isimported}}
                                    </td>
                                    <td class="align-middle" data-field="bgcolor">
                                        <span class="mimo-color-swatch" style="display:inline-block;width:32px;height:20px;border-radius:6px;background:{{bgcolor}};border:1px solid rgba(0,0,0,0.1);"></span>
                                        <span class="ms-2 text-muted small fw-semibold mimo-color-hex">{{bgcolor}}</span>
                                    </td>
                                    <td data-field="activitytype1">{{activitytype1}}</td>
                                    <td data-field="activitytype2">{{activitytype2}}</td>
                                    <td data-field="activitytype3">{{activitytype3}}</td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <a href="#" title="{{edittitle}}" class="btn btn-sm btn-icon" data-testid="edit-tag-button" data-action="edit-tag" data-tag-id="{{id}}">
                                                {{#pix}}i/edit, core, {{edittitle}}{{/pix}}
                                            </a>
                                            {{#isimported}}
                                                <a href="{{promoteurl}}"
                                                   title="{{promotetoglobaltext}}"
                                                   class="btn btn-sm btn-icon text-success"
                                                   data-testid="promote-tag-button"
                                                   data-tag-id="{{id}}">
                                                    {{#pix}}i/publish, core, {{promotetoglobaltext}}{{/pix}}
                                                </a>
                                            {{/isimported}}
                                            {{#isbaseview}}
                                            <a href="{{deleteurl}}"
                                               title="{{deletetitle}}"
                                               class="btn btn-sm btn-icon"
                                               data-action="delete-tag"
                                               data-testid="delete-tag-button"
                                               data-tag-id="{{id}}"
                                               data-tag-name="{{name}}">
                                                {{#pix}}t/delete, core, {{deletetitle}}{{/pix}}
                                            </a>
                                            {{/isbaseview}}
                                        </div>
                                    </td>
                                </tr>
                            {{/tags}}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    {{/hastags}}
</div>
