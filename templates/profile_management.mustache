{{!
    @template format_minimoodlewall/profile_management

    Activity profile management page template.

    Context variables:
    * createprofileurl - URL to create new profile
    * createprofiletext - Text for create profile button
    * noprofilestext - Text when no profiles exist
    * hasprofiles - Boolean if profiles exist
    * tableheaders - Object with table header strings
    * profiles - Array of profile objects

    Example context (json):
    {
        "createprofileurl": "/path/to/create",
        "createprofiletext": "Create profile",
        "hasprofiles": true,
        "tableheaders": {
            "name": "Name",
            "displayname": "Display name",
            "sortorder": "Sort order",
            "actions": "Actions"
        },
        "profiles": [
            {
                "id": 1,
                "name": "classic",
                "displayname": "Classic",
                "sortorder": 1,
                "editurl": "/path/to/edit",
                "deleteurl": "/path/to/delete",
                "edittitle": "Edit profile",
                "deletetitle": "Delete profile"
            }
        ]
    }
}}

<div class="profile-management" data-region="profile-management">
    <div class="mb-3">
        <button type="button" class="btn btn-primary" data-action="create-profile" data-testid="create-profile-button">
            {{createprofiletext}}
        </button>
    </div>

    {{^hasprofiles}}
        <div class="alert alert-info">
            {{noprofilestext}}
        </div>
    {{/hasprofiles}}

    {{#hasprofiles}}
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped generaltable" data-testid="profile-list-table">
                        <thead>
                            <tr>
                                <th>{{tableheaders.name}}</th>
                                <th>{{tableheaders.displayname}}</th>
                                <th>{{tableheaders.sortorder}}</th>
                                <th>{{tableheaders.actions}}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#profiles}}
                                <tr data-testid="profile-row" data-profile-id="{{id}}" data-profile-name="{{name}}">
                                    <td><code>{{name}}</code></td>
                                    <td>{{displayname}}</td>
                                    <td>{{sortorder}}</td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <a href="#" title="{{edittitle}}" class="btn btn-sm btn-icon" data-testid="edit-profile-button" data-action="edit-profile" data-profile-id="{{id}}">
                                                {{#pix}}i/edit, core, {{edittitle}}{{/pix}}
                                            </a>
                                            <a href="{{deleteurl}}"
                                               title="{{deletetitle}}"
                                               class="btn btn-sm btn-icon"
                                               data-action="delete-profile"
                                               data-testid="delete-profile-button"
                                               data-profile-id="{{id}}"
                                               data-profile-name="{{name}}">
                                                {{#pix}}t/delete, core, {{deletetitle}}{{/pix}}
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {{/profiles}}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    {{/hasprofiles}}
</div>
