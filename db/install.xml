<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="course/format/minimoodlewall/db" VERSION="20260226" COMMENT="XMLDB file for Moodle course/format/minimoodlewall"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="format_minimoodlewall_profiles" COMMENT="Activity profiles for minimoodlewall course format">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="name" TYPE="char" LENGTH="50" NOTNULL="true" SEQUENCE="false" COMMENT="Internal identifier (e.g., classic, light, dark)"/>
        <FIELD NAME="displayname" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false" COMMENT="Human-readable name"/>
        <FIELD NAME="sortorder" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Display order"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="name_unique" UNIQUE="true" FIELDS="name"/>
        <INDEX NAME="sortorder" UNIQUE="false" FIELDS="sortorder"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="format_minimoodlewall_profile_tags" COMMENT="Per-profile overrides for tags (images, name, activity types, enabled state)">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="tagid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Reference to tag"/>
        <FIELD NAME="profileid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Reference to profile"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false" COMMENT="Override tag name (NULL = use base tag name)"/>
        <FIELD NAME="bgcolor" TYPE="char" LENGTH="7" NOTNULL="false" SEQUENCE="false" COMMENT="Override background color (NULL = use base)"/>
        <FIELD NAME="activitytype1" TYPE="char" LENGTH="50" NOTNULL="false" SEQUENCE="false" COMMENT="Override first activity type (NULL = use base)"/>
        <FIELD NAME="activitytype2" TYPE="char" LENGTH="50" NOTNULL="false" SEQUENCE="false" COMMENT="Override second activity type (NULL = use base)"/>
        <FIELD NAME="activitytype3" TYPE="char" LENGTH="50" NOTNULL="false" SEQUENCE="false" COMMENT="Override third activity type (NULL = use base)"/>
        <FIELD NAME="enabled" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1" SEQUENCE="false" COMMENT="Whether tag is available in this profile"/>
        <FIELD NAME="imgplacement" TYPE="char" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Override image placement (NULL = use base)"/>
        <FIELD NAME="imgsize" TYPE="char" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Override image size (NULL = use base)"/>
        <FIELD NAME="cardimage" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false" COMMENT="Filename for card image"/>
        <FIELD NAME="filterimage" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false" COMMENT="Filename for filter bar image"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="tagid" TYPE="foreign" FIELDS="tagid" REFTABLE="format_minimoodlewall_tags" REFFIELDS="id"/>
        <KEY NAME="profileid" TYPE="foreign" FIELDS="profileid" REFTABLE="format_minimoodlewall_profiles" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="tagid_profileid_unique" UNIQUE="true" FIELDS="tagid, profileid" COMMENT="Each tag can have only one config per profile"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="format_minimoodlewall_tags" COMMENT="Activity tags for course wall display">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false" COMMENT="Name of the tag"/>
        <FIELD NAME="cardimage" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false" COMMENT="Filename for card image"/>
        <FIELD NAME="imgplacement" TYPE="char" LENGTH="10" NOTNULL="true" DEFAULT="center" SEQUENCE="false" COMMENT="Image placement (center or lower)"/>
        <FIELD NAME="imgsize" TYPE="char" LENGTH="10" NOTNULL="true" DEFAULT="normal" SEQUENCE="false" COMMENT="Image size (bigger, normal, or smaller)"/>
        <FIELD NAME="filterimage" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false" COMMENT="Filename for filter bar image"/>
        <FIELD NAME="bgcolor" TYPE="char" LENGTH="7" NOTNULL="false" SEQUENCE="false" COMMENT="Hex card background colour"/>
        <FIELD NAME="activitytype1" TYPE="char" LENGTH="50" NOTNULL="false" SEQUENCE="false" COMMENT="First suggested activity type"/>
        <FIELD NAME="activitytype2" TYPE="char" LENGTH="50" NOTNULL="false" SEQUENCE="false" COMMENT="Second suggested activity type"/>
        <FIELD NAME="activitytype3" TYPE="char" LENGTH="50" NOTNULL="false" SEQUENCE="false" COMMENT="Third suggested activity type"/>
        <FIELD NAME="sortorder" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Display order"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="sortorder" UNIQUE="false" FIELDS="sortorder"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="format_minimoodlewall_cmtags" COMMENT="Maps course modules to tags">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="cmid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Course module ID"/>
        <FIELD NAME="tagid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Tag ID"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="cmid" TYPE="foreign" FIELDS="cmid" REFTABLE="course_modules" REFFIELDS="id"/>
        <KEY NAME="tagid" TYPE="foreign" FIELDS="tagid" REFTABLE="format_minimoodlewall_tags" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="cmid_unique" UNIQUE="true" FIELDS="cmid" COMMENT="Each course module can have only one tag"/>
        <INDEX NAME="tagid" UNIQUE="false" FIELDS="tagid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="format_minimoodlewall_actdesc" COMMENT="Activity type descriptions for tag chooser modal">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="activitytype" TYPE="char" LENGTH="50" NOTNULL="true" SEQUENCE="false" COMMENT="Activity module name (e.g., assign, quiz)"/>
        <FIELD NAME="description" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Short description for modal"/>
        <FIELD NAME="desctagid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Reference to description tag"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="desctagid" TYPE="foreign" FIELDS="desctagid" REFTABLE="format_minimoodlewall_desc_tags" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="activitytype_unique" UNIQUE="true" FIELDS="activitytype"/>
        <INDEX NAME="desctagid" UNIQUE="false" FIELDS="desctagid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="format_minimoodlewall_desc_tags" COMMENT="Tags for categorizing activity descriptions">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false" COMMENT="Tag name"/>
        <FIELD NAME="color" TYPE="char" LENGTH="7" NOTNULL="true" SEQUENCE="false" COMMENT="Hex color code (e.g., #FF5733)"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
    </TABLE>
  </TABLES>
</XMLDB>
